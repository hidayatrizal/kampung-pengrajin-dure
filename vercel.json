{
  "version": 2,
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.9.0"
    }
  },
  "build": {
    "env": {
      "IS_NOW": "1"
    },
    "outputDirectory": "public"
  },
  "buildCommand": "npm run build && php artisan storage:link --relative 2>/dev/null || true",
  "routes": [
    {
      "src": "/build/assets/(.*)",
      "dest": "/public/build/assets/$1"
    },
    {
      "src": "/storage/(.*)",
      "dest": "/api/index.php"
    },
    {
      "src": "/hero\\.webp",
      "dest": "/public/hero.webp"
    },
    {
      "src": "/hero\\.png",
      "dest": "/public/hero.png"
    },
    {
      "src": "/genteng1\\.jpeg",
      "dest": "/public/genteng1.jpeg"
    },
    {
      "src": "/favicon\\.ico",
      "headers": {
        "Content-Type": "image/x-icon"
      },
      "dest": "/public/favicon.ico"
    },
    {
      "src": "/(.*\\.(css|js|jpg|jpeg|png|gif|svg|webp|ico|woff|woff2|ttf|eot))",
      "dest": "/public/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.php"
    }
  ],
  "env": {
    "APP_NAME": "Desa Pengrajin Dure",
    "APP_ENV": "production",
    "APP_DEBUG": "false",
    "LOG_CHANNEL": "stderr",
    "CACHE_DRIVER": "array",
    "SESSION_DRIVER": "cookie",
    "VIEW_COMPILED_PATH": "/tmp/views",
    "VERCEL": "1"
  }
}
