{
  "version": 2,
  "framework": null,
  "outputDirectory": "public",
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.9.0"
    }
  },
  "build": {
    "env": {
      "IS_NOW": "1",
      "APP_KEY": "base64:RySmqNnqCZRsKrPBVIDxV2Xbrw+uFErqpd2ozSDLhpY="
    }
  },
  "buildCommand": "npm run build && php artisan package:discover --ansi 2>/dev/null; php artisan storage:link --relative 2>/dev/null; true",
  "routes": [
    {
      "src": "/build/(.*)",
      "dest": "/build/$1"
    },
    {
      "src": "/storage/(.*)",
      "dest": "/api/index.php"
    },
    {
      "src": "/favicon\\.ico",
      "headers": { "Content-Type": "image/x-icon" },
      "dest": "/favicon.ico"
    },
    {
      "src": "/(.*\\.(css|js|jpg|jpeg|png|gif|svg|webp|ico|woff|woff2|ttf|eot))",
      "dest": "/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.php"
    }
  ],
  "env": {
    "APP_NAME": "Desa Pengrajin Dure",
    "APP_ENV": "production",
    "APP_DEBUG": "false",
    "APP_KEY": "base64:RySmqNnqCZRsKrPBVIDxV2Xbrw+uFErqpd2ozSDLhpY=",
    "APP_URL": "https://kampung-pengrajin-dure.vercel.app",
    "LOG_CHANNEL": "stderr",
    "CACHE_DRIVER": "array",
    "SESSION_DRIVER": "cookie",
    "VIEW_COMPILED_PATH": "/tmp/views",
    "APP_CONFIG_CACHE": "/tmp/config.php",
    "DB_CONNECTION": "pgsql",
    "DB_HOST": "ep-noisy-sea-aqasinw1-pooler.c-8.us-east-1.aws.neon.tech",
    "DB_PORT": "5432",
    "DB_DATABASE": "neondb",
    "DB_USERNAME": "neondb_owner",
    "DB_PASSWORD": "npg_0QycCZO1JHKM",
    "DB_SSLMODE": "require",
    "VERCEL": "1"
    "CLOUDINARY_URL": "cloudinary://545677955221147:cXBR_JdsEWf5AtEoASr5hnk0XU@djkczwulv"
}
  }
}
